# Use the pre-built base image for Agent Zero
FROM agent0ai/agent-zero-base:latest

# Set Hugging Face specific environment variables
ENV HF_SPACE=true
ENV WEB_UI_PORT=7860
ENV HOME=/a0
ENV PYTHONUNBUFFERED=1

# Expose the default Hugging Face port
EXPOSE 7860

# Create application directory
WORKDIR /app

# Copy adapted files and startup script
COPY helpers/api.py helpers/api.py
COPY helpers/ui_server.py helpers/ui_server.py
COPY helpers/runtime.py helpers/runtime.py
COPY start_hf.sh start_hf.sh

# Ensure script is executable
RUN chmod +x start_hf.sh

# Run the startup script
ENTRYPOINT ["/bin/bash", "/app/start_hf.sh"]
